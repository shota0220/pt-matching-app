generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id             String         @id @default(cuid())
  email          String         @unique
  password       String
  name           String
  gender         String?
  height         Float?
  weight         Float?
  medicalHistory String?      
  symptom        String?
  address        String?
  isApproved     Boolean        @default(false)
  lat            Float?   
  lng            Float?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  
  // リレーション
  chats          Chat[]
  matchRequests  MatchRequest[]
  reservations   Reservation[]
  reviews        Review[]
  messages       Message[]      // 詳細チャット用に追加
  clinicalRecords ClinicalRecord[] // 患者側からもカルテを参照可能にする場合
}

model Therapist {
  id            String         @id @default(cuid())
  name          String
  email         String         @unique
  password      String
  specialty     String
  experience    Int            @default(0)
  message       String?        
  license       String?
  photo         String?
  lat           Float
  lng           Float
  walletBalance Int            @default(0)
  rating        Float          @default(4.0)
  price         Int            @default(5000)
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  tags          String?        @default("[]")

  // リレーション
  chats           Chat[]
  matchRequests   MatchRequest[]
  reservations    Reservation[]
  reviews         Review[]
  messages        Message[]        // 詳細チャット用に追加
  clinicalRecords ClinicalRecord[] // SOAPカルテ（重要）
}

model Reservation {
  id          String    @id @default(cuid())
  userId      String
  therapistId String
  date        DateTime
  price       Int
  status      String    @default("PENDING") // PENDING, CONFIRMED, COMPLETED, CANCELLED
  createdAt   DateTime  @default(now())

  therapist   Therapist @relation(fields: [therapistId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

// 簡易チャット履歴（既存）
model Chat {
  id          Int      @id @default(autoincrement())
  userId      String
  therapistId String
  message     String   
  // APIコードの sender に合わせて名称変更
  sender      String   @default("USER") // "USER" or "THERAPIST"
  createdAt   DateTime @default(now())

  therapist   Therapist @relation(fields: [therapistId], references: [id])
  user        User      @relation(fields: [userId], references: [id])
}

// 詳細チャットメッセージ（api/chat/route.ts などで使用）
model Message {
  id          String   @id @default(cuid())
  content     String   
  senderType  String   // "USER" or "THERAPIST"
  userId      String
  therapistId String
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

model MatchRequest {
  id          String   @id @default(cuid())
  therapistId String
  userId      String
  status      String   @default("PENDING") // PENDING, APPROVED, REJECTED
  message     String?  
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

model Review {
  id          String   @id @default(cuid())
  rating      Int
  comment     String   
  userId      String
  therapistId String
  createdAt   DateTime @default(now())

  user        User      @relation(fields: [userId], references: [id])
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}

// --- 追加分：専門的なリハビリDX機能を繋ぐモデル ---

// SOAPカルテ（api/clinical/soap/route.ts で使用）
model ClinicalRecord {
  id          String   @id @default(cuid())
  userId      String
  therapistId String
  subjective  String?   // S: 患者さんの訴え
  objective   String?   // O: 可動域や筋力などの客観データ
  assessment  String?   // A: AIによる分析やセラピストの判断
  plan        String?   // P: 次回のリハビリ方針
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user        User      @relation(fields: [userId], references: [id])
  therapist   Therapist @relation(fields: [therapistId], references: [id])
}